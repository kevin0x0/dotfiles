set -e

COLOR_THEME_FILE=$COLORSCHEME_STATE_HOME/neomutt/current_theme
if [ ! -e  "$(dirname -- $COLOR_THEME_FILE)" ]; then
  if ! mkdir -p "$(dirname -- $COLOR_THEME_FILE)"; then
    echo "can not create state file for neumutt" >&2
    exit 1
  fi
fi

case $1 in
  dark)
    color=256-dark
    ;;
  *)
    color=256-light
    ;;
esac

printf "%s\n" "$color" > "$COLOR_THEME_FILE"

