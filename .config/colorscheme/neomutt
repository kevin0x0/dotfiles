set -e

COLOR_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/neomutt/current_theme"
if [ ! -e  "$(dirname -- $COLOR_STATE)" ]; then
  if ! mkdir -p "$(dirname -- $COLOR_STATE)"; then
    echo "can not create state file for neumutt" >&2
    exit 1
  fi
fi

case $1 in
  dark)
    color=256-dark
    ;;
  *)
    color=256-light
    ;;
esac

printf "%s\n" "$color" > "$COLOR_STATE"

