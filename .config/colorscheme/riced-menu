set -e

COLOR_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/riced-menu/current_theme"
if [ ! -e  "$(dirname -- $COLOR_STATE)" ]; then
  if ! mkdir -p "$(dirname -- $COLOR_STATE)"; then
    echo "can not create state file for riced-menu" >&2
    exit 1
  fi
fi

case $1 in
  dark)
    theme=DARK_COLORS
    ;;
  *)
    theme=LIGHT_COLORS
    ;;
esac

printf "%s\n" "$theme" > "$COLOR_STATE"

# vim: ft=sh
