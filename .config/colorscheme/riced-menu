set -e

COLOR_THEME_FILE=$COLORSCHEME_STATE_HOME/riced-menu/current_theme
if [ ! -e  "$(dirname -- $COLOR_THEME_FILE)" ]; then
  if ! mkdir -p "$(dirname -- $COLOR_THEME_FILE)"; then
    echo "can not create state file for riced-menu" >&2
    exit 1
  fi
fi

case $1 in
  dark)
    theme=DARK_COLORS
    ;;
  *)
    theme=LIGHT_COLORS
    ;;
esac

printf "%s\n" "$theme" > "$COLOR_THEME_FILE"

