
FONTFAMILY='monospace'
# Font by fontconfig format
FONT="$FONTFAMILY, Bold 14"

DARK_COLORS='-S cba6f7 -s 1e1e2e -N 1e1e2e -n cdd6f4 -M 313244 -m 89b4fa'
LIGHT_COLORS='-S f2ebe5 -s 3f2f24 -N f2ebe5 -n b55a45 -M f2ebe5 -m d79f70'

COLORS=$DARK_COLORS
colorfile="${XDG_STATE_HOME:-$HOME/.local/state}/colorscheme/riced-menu/current_theme"

if [ -r "$colorfile" ]; then
  eval "COLORS=\$$(cat -- "$colorfile")"
fi

