set -e

theme=$1

COLOR_THEME_FILE=$COLORSCHEME_STATE_HOME/foot/colortheme.ini

if [ ! -f "$COLOR_THEME_FILE" ]; then
  echo "$COLOR_THEME_FILE doesn't exist" >&2
  exit 1
fi

case $theme in
  dark)
    pkill -USR1 foot || true
    ;;
  *)
    pkill -USR2 foot || true
    theme=light
    ;;
esac

printf "initial-color-theme=%s\n" "$theme" > "$COLOR_THEME_FILE"

# vim: ft=sh
