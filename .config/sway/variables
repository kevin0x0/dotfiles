
# set variables
set $mod Mod4
# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

set $term foot
set $menu riced-wmenu-run
set $proxy 'SUDO_ASKPASS="$HOME/.local/bin/riced-wmenu-askpass" clash-start --askpass || \
          { [ $LANG = "zh_CN.UTF-8" ] && notify-send --app-name "clash-start" "错误" "Clash 启动失败"; } || \
            notify-send --app-name "clash-start" "Error" "Clash unable to start." '
set $broswer firefox
set $musicplayer /opt/YesPlayMusic/yesplaymusic

set $gnome-schema org.gnome.desktop.interface

set $background /home/kevin/pictures/background/mirror.png

set $font JetBrainsMonoNL Nerd Font Mono
set $gtk-theme Materia
set $icon-theme Adwaita
set $cursor-theme capitaine-cursors

# vim: ft=swayconfig
