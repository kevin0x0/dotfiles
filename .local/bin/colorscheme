#!/bin/sh

set -e

theme=$1
COLORSCHEME_STATE_HOME=${XDG_STATE_HOME:-$HOME/.local/state}/colorscheme

if [ ! -d "$COLORSCHEME_STATE_HOME" ]; then
  if [ -e "$COLORSCHEME_STATE_HOME" ]; then
    echo "'$COLORSCHEME_STATE_HOME' exists but not a directory" >&2
    exit 1
  fi

  mkdir -p -- "$COLORSCHEME_STATE_HOME"
fi


COLOR_THEME_FILE=$COLORSCHEME_STATE_HOME/current_theme

if [ ! -f "$COLOR_THEME_FILE" ]; then
  if [ -e "$COLOR_THEME_FILE" ]; then
    echo "'$COLOR_THEME_FILE' exists but not a file" >&2
    exit 1
  fi
  
  printf "%s\n" 'light' >"$COLOR_THEME_FILE"
fi

if [ -z "$theme" ]; then
  current_theme=$(cat "$COLOR_THEME_FILE")
  case $current_theme in
    dark)
      theme=light
      ;;
    light)
      theme=dark
      ;;
      *)
      theme=dark
      ;;
  esac
fi

CONFIG_DIR=${XDG_CONFIG_HOME:-$HOME/.config}/colorscheme

if [ ! -d "$CONFIG_DIR" ]; then
  echo "'$CONFIG_DIR' doesn't exist or not a directory" >&2
  exit 1
fi

export COLORSCHEME_STATE_HOME
for script in "$CONFIG_DIR"/*; do
  sh -- "$script" "$theme"
done

printf "%s\n" "$theme" >"$COLOR_THEME_FILE"
