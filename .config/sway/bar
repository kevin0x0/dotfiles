#
# Status Bar:
#
# Read `man 5 sway-bar` for more information about this section.
bar {
    font "JetBrainsMonoNL Nerd Font Mono" Bold 12
    gaps 4
    position top
    tray_padding 4
    separator_symbol "  "
    set icon_theme Adwaita

    # When the status_command prints a new line to stdout, swaybar updates.
    # The default just shows the current date and time.
    # status_command while date +'%Y-%m-%d %X'; do sleep 1; done
    status_command i3status
    colors {
        separator #B8E8C4
        statusline #B8E4F0
        background #A8D0D418
        focused_workspace #A8D0D418 #A8D0D418 #B8F0E4
        active_workspace #A8D0D418 #A8D0D418 #FFF0C8
        inactive_workspace #A8D0D418 #A8D0D418 #687A90
        urgent_workspace #A8D0D418 #A8D0D418 #FF4060
    }
}

# vim: ft=swayconfig
