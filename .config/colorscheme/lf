set -e

COLOR_STATE="${XDG_STATE_HOME:-$HOME/.local/state}/lf/current_theme"

if [ ! -e "$(dirname -- $COLOR_STATE)" ]; then
  if ! mkdir -p "$(dirname -- $COLOR_STATE)"; then
    echo "can not create state file for lf" >&2
    exit 1
  fi
fi

case $1 in
  dark)
    color=256-dark
    ;;
  *)
    color=256-light
    ;;
esac

printf "%s\n" "$color" > "$COLOR_STATE"

lf -remote 'send on-init' >/dev/null 2>&1 || true
# vim: ft=sh
